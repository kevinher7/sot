{
  "name": "sot-extension",
  "version": "1.2.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.14.0",
    "npm": "11.9.0"
  },
  "scripts": {
    "dev:firefox": "EXTENSION_TARGET=firefox vite build --watch",
    "dev:chromium": "EXTENSION_TARGET=chromium vite build --watch",
    "dev": "npm run dev:firefox",
    "build:firefox": "EXTENSION_TARGET=firefox vite build",
    "build:chromium": "EXTENSION_TARGET=chromium vite build",
    "build": "npm run build:firefox && npm run build:chromium",
    "package:firefox": "mkdir -p releases && cd dist-firefox && zip -r ../releases/firefox.xpi .",
    "package:chromium": "mkdir -p releases && cd dist-chromium && zip -r ../releases/chromium.zip .",
    "release:prepare": "npm run build && npm run package:firefox && npm run package:chromium",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "prettier": "npm run format"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^25.6.0",
    "@types/webextension-polyfill": "^0.12.5",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.1.12"
  }
}
