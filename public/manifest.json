{
  "manifest_version": 3,
  "name": "KOT Extension",
  "description": "Overlay helpers for the KING OF TIME monthly working page.",
  "version": "0.0.1",
  "browser_specific_settings": {
    "gecko": {
      "id": "kot-extension@example.local"
    }
  },
  "host_permissions": ["https://s2.ta.kingoftime.jp/admin/*"],
  "content_scripts": [
    {
      "matches": ["https://s2.ta.kingoftime.jp/admin/*"],
      "js": ["content/index.js"],
      "css": ["content/index.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"]
}
