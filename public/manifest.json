{
  "manifest_version": 3,
  "name": "SOT (SERVANT OF TIME)",
  "description": "Unofficial extension overlay for the KING OF TIME timecard",
  "version": "0.0.1",
  "icons": {
    "48": "icons/sot-48.png",
    "96": "icons/sot-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "sot-extension@example.local"
    }
  },
  "host_permissions": ["https://s2.ta.kingoftime.jp/admin/*"],
  "content_scripts": [
    {
      "matches": ["https://s2.ta.kingoftime.jp/admin/*"],
      "js": ["content/index.js"],
      "css": ["content/index.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"]
}
